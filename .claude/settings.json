{
  "permissions": {
    "allow": [
      "mcp__context7__*",
      "mcp__github__*",
      "mcp__supabase__*",
      "mcp__playwright__*",
      "mcp__sequential-thinking__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo $TOOL_INPUT | grep -o '\"file_path\":\"[^\"]*\"' | cut -d'\"' -f4); if [[ \"$file\" == *.ts || \"$file\" == *.tsx ]]; then cd /Users/adamkahirov/Desktop/code/ak-automation && npx tsc --noEmit 2>&1 | head -10; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date '+%Y-%m-%d %H:%M') session ended\" >> /Users/adamkahirov/Desktop/code/ak-automation/ops/session-log.txt"
          }
        ]
      }
    ]
  }
}
